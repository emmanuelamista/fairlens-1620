{
  "functions": {
    "api/main.py": {
      "runtime": "@vercel/python@4.5.0"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/main.py"
    },
    {
      "src": "/FairLens_CaseStudy.pdf",
      "dest": "/frontend/FairLens_CaseStudy.pdf"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
